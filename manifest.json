{
  "name": "hubble-timer",
  "version": "2.0.0",
  "description": "A cooking timer with countdown and stopwatch modes.",
  "category": "clock",
  "minAppVersion": "0.1.0",
  "type": [
    "connector",
    "visualization"
  ],
  "events": [
    {
      "name": "timer:started",
      "description": "A timer began counting",
      "payload": {
        "slug": {
          "type": "string",
          "description": "Timer identifier (e.g. timer-1)"
        },
        "label": {
          "type": "string",
          "description": "Display label for this run"
        },
        "mode": {
          "type": "string",
          "enum": [
            "countdown",
            "stopwatch"
          ],
          "description": "Timer mode"
        },
        "duration": {
          "type": "number",
          "description": "Duration in seconds (countdown only)"
        }
      }
    },
    {
      "name": "timer:paused",
      "description": "A timer was paused",
      "payload": {
        "slug": {
          "type": "string",
          "description": "Timer identifier"
        },
        "elapsed": {
          "type": "number",
          "description": "Elapsed time in seconds"
        }
      }
    },
    {
      "name": "timer:resumed",
      "description": "A paused timer was resumed",
      "payload": {
        "slug": {
          "type": "string",
          "description": "Timer identifier"
        },
        "elapsed": {
          "type": "number",
          "description": "Elapsed time in seconds"
        }
      }
    },
    {
      "name": "timer:finished",
      "description": "A countdown completed",
      "payload": {
        "slug": {
          "type": "string",
          "description": "Timer identifier"
        },
        "label": {
          "type": "string",
          "description": "Display label"
        },
        "duration": {
          "type": "number",
          "description": "Total duration in seconds"
        }
      }
    },
    {
      "name": "timer:reset",
      "description": "A timer was reset to idle",
      "payload": {
        "slug": {
          "type": "string",
          "description": "Timer identifier"
        }
      }
    }
  ],
  "endpoints": [
    {
      "name": "start",
      "method": "POST",
      "path": "/start",
      "description": "Start or restart a timer",
      "body": {
        "type": "object",
        "required": [
          "slug"
        ],
        "properties": {
          "slug": {
            "type": "string",
            "description": "Widget slug to target"
          },
          "duration": {
            "type": "number",
            "description": "Duration in seconds (omit for stopwatch)"
          },
          "label": {
            "type": "string",
            "description": "Optional display label for this run"
          }
        }
      }
    },
    {
      "name": "pause",
      "method": "POST",
      "path": "/pause",
      "description": "Pause a running timer",
      "body": {
        "type": "object",
        "required": [
          "slug"
        ],
        "properties": {
          "slug": {
            "type": "string",
            "description": "Widget slug to target"
          }
        }
      }
    },
    {
      "name": "resume",
      "method": "POST",
      "path": "/resume",
      "description": "Resume a paused timer",
      "body": {
        "type": "object",
        "required": [
          "slug"
        ],
        "properties": {
          "slug": {
            "type": "string",
            "description": "Widget slug to target"
          }
        }
      }
    },
    {
      "name": "reset",
      "method": "POST",
      "path": "/reset",
      "description": "Reset a timer to idle",
      "body": {
        "type": "object",
        "required": [
          "slug"
        ],
        "properties": {
          "slug": {
            "type": "string",
            "description": "Widget slug to target"
          }
        }
      }
    },
    {
      "name": "start-available",
      "method": "POST",
      "path": "/start-available",
      "description": "Start the first available idle timer",
      "public": true,
      "body": {
        "type": "object",
        "required": [
          "duration",
          "label"
        ],
        "properties": {
          "duration": {
            "type": "number",
            "description": "Duration in seconds"
          },
          "label": {
            "type": "string",
            "description": "Timer display label"
          }
        }
      }
    }
  ],
  "visualizations": [
    {
      "name": "Countdown",
      "description": "Circular ring countdown timer, green to red",
      "path": "countdown",
      "selectable": true,
      "hardwareButtons": {
        "button1": "toggle",
        "button2": "reset"
      },
      "properties": [
        {
          "name": "title",
          "type": "string",
          "required": true,
          "description": "Display name when no API label is active"
        },
        {
          "name": "slug",
          "type": "string",
          "required": true,
          "description": "Stable API identifier (e.g. timer-1)"
        },
        {
          "name": "size",
          "type": "choice",
          "required": false,
          "default": "m",
          "description": "Widget size",
          "choices": [
            {
              "label": "Small",
              "value": "s"
            },
            {
              "label": "Medium",
              "value": "m"
            },
            {
              "label": "Large",
              "value": "l"
            },
            {
              "label": "Extra Large",
              "value": "xl"
            }
          ]
        },
        {
          "name": "doneNotify",
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Send notification when done"
        },
        {
          "name": "doneExpand",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Expand full-screen when done (requires hardware button to dismiss)"
        },
        {
          "name": "doneFlash",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Flash the widget when done"
        },
        {
          "name": "doneSelect",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Select this widget on the dashboard when done"
        },
        {
          "name": "warningThreshold",
          "type": "range",
          "required": false,
          "default": 300,
          "description": "Seconds remaining when ring turns red",
          "min": 0,
          "max": 3600,
          "step": 30
        },
        {
          "name": "doneAutoReset",
          "type": "range",
          "required": false,
          "default": 0,
          "description": "Auto-reset after done (minutes, 0 = never)",
          "min": 0,
          "max": 60,
          "step": 1
        }
      ]
    },
    {
      "name": "Stopwatch",
      "description": "Digital elapsed time stopwatch",
      "path": "stopwatch",
      "selectable": true,
      "hardwareButtons": {
        "button1": "toggle",
        "button2": "reset"
      },
      "properties": [
        {
          "name": "title",
          "type": "string",
          "required": true,
          "description": "Display name when no API label is active"
        },
        {
          "name": "slug",
          "type": "string",
          "required": true,
          "description": "Stable API identifier (e.g. timer-1)"
        },
        {
          "name": "size",
          "type": "choice",
          "required": false,
          "default": "m",
          "description": "Widget size",
          "choices": [
            {
              "label": "Small",
              "value": "s"
            },
            {
              "label": "Medium",
              "value": "m"
            },
            {
              "label": "Large",
              "value": "l"
            },
            {
              "label": "Extra Large",
              "value": "xl"
            }
          ]
        },
        {
          "name": "doneNotify",
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Send notification when done"
        },
        {
          "name": "doneExpand",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Expand full-screen when done (requires hardware button to dismiss)"
        },
        {
          "name": "doneFlash",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Flash the widget when done"
        },
        {
          "name": "doneSelect",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Select this widget on the dashboard when done"
        },
        {
          "name": "showMilliseconds",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Show .xx subsecond suffix in smaller text"
        }
      ]
    },
    {
      "name": "Date Countdown",
      "description": "Counts down to a configured date/time with adaptive precision",
      "path": "date-countdown",
      "selectable": true,
      "properties": [
        {
          "name": "title",
          "type": "string",
          "required": true,
          "description": "Event name displayed on the widget"
        },
        {
          "name": "targetDate",
          "type": "datetime",
          "required": true,
          "description": "The date/time to count down to"
        },
        {
          "name": "layout",
          "type": "choice",
          "required": false,
          "default": "hero",
          "description": "Display layout",
          "choices": [
            {
              "label": "Hero Number",
              "value": "hero"
            },
            {
              "label": "Segmented",
              "value": "segmented"
            }
          ]
        },
        {
          "name": "size",
          "type": "choice",
          "required": false,
          "default": "m",
          "description": "Widget size",
          "choices": [
            {
              "label": "Small",
              "value": "s"
            },
            {
              "label": "Medium",
              "value": "m"
            },
            {
              "label": "Large",
              "value": "l"
            },
            {
              "label": "Extra Large",
              "value": "xl"
            }
          ]
        },
        {
          "name": "doneNotify",
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Send a notification when the date arrives"
        },
        {
          "name": "doneExpand",
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Expand full-screen (requires hardware button to dismiss) when the date arrives"
        }
      ]
    }
  ]
}
